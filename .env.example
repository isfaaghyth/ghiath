DOMAIN_NAME=ghiath.id
ENVIRONMENT=local

# ---------------------------------------------------------------------------
# Upstream LLM provider keys.
# Preferred model: leave these BLANK and add your real Anthropic / OpenRouter
# keys inside the KeiRouter dashboard instead, then point the agents at
# KeiRouter with a virtual key (see README "Routing through KeiRouter").
# Only fill these if you deliberately bypass KeiRouter and call providers
# directly from a hermes profile or an n8n node.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# KeiRouter requires a base64-encoded 32-byte key. Generate with:
#   openssl rand -base64 32
KEIROUTER_MASTER_KEY=generate_with_openssl_rand_base64_32
# Any random string. Generate with: openssl rand -hex 24
N8N_ENCRYPTION_KEY=generate_a_random_string
COUCHDB_USER=admin
# Use a strong value - CouchDB is the only auth in front of your synced vault.
# Generate with: openssl rand -hex 16
COUCHDB_PASSWORD=generate_a_random_string

# Agent names, models, vault folders and ports live in agents.conf (copy it from
# agents.conf.example). The vault/collection names below are GENERATED from it
# into a managed block at the bottom of this file - do not set them by hand:
#   ./scripts/sync-env.sh --write

# --- Telegram ---------------------------------------------------------------
# Two SEPARATE @BotFather bots, one per agent. Keeping them separate is what
# stops the household bot from ever reaching the work vault.
#
# Create each bot, paste its token here, then run ./scripts/hermes.sh - it
# writes each token into the matching profile so its gateway connects the bot.
# Leave a token blank to skip that bot. Changing a token here and re-running
# hermes.sh re-binds only that bot; everything else is left alone.
#
# The work bot also accepts the older name TELEGRAM_BOT_TOKEN.
WORK_TELEGRAM_BOT_TOKEN=
HOME_TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# Production only (VPS). Leave defaults for local dev.
# ---------------------------------------------------------------------------
ACME_EMAIL=you@example.com

# Basic-auth credentials for the protected Caddy subdomains (n8n, router,
# hermes). Generate the bcrypt hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'your-password'
# IMPORTANT: keep the single quotes around the hash. bcrypt hashes contain '$',
# which bash and docker compose would otherwise try to expand and corrupt.
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=''

# n8n prod URL settings. n8n is an optional add-on (docker compose --profile
# addon up -d); these only matter if you actually start it. On the VPS set them
# to your real host so login cookies and webhook URLs are correct.
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
# Set to true in prod (Caddy serves HTTPS); keep false for plain-http local.
N8N_SECURE_COOKIE=false

# --- Obsidian LiveSync -------------------------------------------------------
# CouchDB database names. Whatever you set here is what you type into the
# Self-hosted LiveSync plugin's "Database name" on every device.
LIVESYNC_DB=ghiath
LIVESYNC_HOME_DB=ghiath-home

# End-to-end encryption. Leave EMPTY to keep E2EE off (CouchDB is already behind
# HTTPS + auth). If you set it, you must enable E2EE in the Obsidian plugin with
# the exact same passphrase, or the bridge and your devices cannot read each other.
LIVESYNC_PASSPHRASE=

# Your Telegram chat id, if a script needs to reach you directly.
# Get it by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID=

# --- ntfy (reminder alarms) --------------------------------------------------
# scripts/hermes-cron/reminder-tick.py publishes urgent phone alarms to ntfy
# when a reminder note comes due. See REMINDERS.md for the full runbook.
#
# NTFY_BASE_URL is the PUBLIC url of this ntfy instance (what your phone talks
# to). Set it to your own subdomain in prod, e.g. https://ntfy.example.com. It
# defaults to the local loopback port for dev.
# The two topics below are the predefined ones. They are deliberately separate:
#   NTFY_TOPIC       WORK reminders.      Subscribed by your phone only.
#   NTFY_HOME_TOPIC  HOUSEHOLD reminders. Subscribed by both phones.
# Keep them distinct. If they were the same topic, every household reminder
# would also ring on the work subscription, and ntfy's per-topic access control
# (which is what keeps work alarms off your partner's phone) would be pointless.
#
# NTFY_TOKEN authorizes publishing and is created AFTER first start (deny-all).
# The publisher account is separate from the accounts the phones log in with:
#   docker compose exec ntfy ntfy user add --role=admin ghiath
#   docker compose exec ntfy ntfy token add ghiath
# Paste the tk_... token below. See REMINDERS.md for the phone accounts.
NTFY_BASE_URL=http://localhost:8080
NTFY_URL=http://ntfy:80
NTFY_TOPIC=ghiath-work-alarm
NTFY_HOME_TOPIC=ghiath-home-alarm
NTFY_TOKEN=
