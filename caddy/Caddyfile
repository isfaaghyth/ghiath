# Ghiath - production ingress (VPS only).
#
# Used only when Caddy runs under the "prod" compose profile on the VPS:
#     docker compose --profile prod up -d
#
# Caddy obtains and renews Let's Encrypt certificates automatically the first
# time each hostname is requested. Certificates persist in the "caddy_data"
# volume across restarts.
#
# Auth model: only Caddy (80/443) is public; every upstream binds to 127.0.0.1.
# Each app provides its own authentication (KeiRouter dashboard login, CouchDB
# user/password, ntfy tokens, n8n owner account), so basic_auth is applied ONLY
# where a human-facing dashboard benefits from an extra gate - not in front of
# full web apps or API endpoints, where it causes repeated prompts
# (SPA/websocket) or collides with Bearer tokens (API calls).
#
# The agents are deliberately absent from this file. A hermes gateway is a
# Telegram poller, not an inbound HTTP server, so there is nothing to proxy and
# nothing that needs to be publicly reachable.

{
	email {$ACME_EMAIL}
}

# Reusable basic_auth snippet. bcrypt hash comes from the environment.
(protected) {
	basic_auth {
		{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
	}
}

# Root domain: static placeholder for now.
ghiath.id {
	respond "hello world"
}

# n8n - the optional add-on. This block only resolves to anything when the
# "addon" compose profile is running; otherwise Caddy returns a 502 here, which
# is the intended behaviour. No basic_auth: layering it over n8n's SPA and
# websocket connection causes the auth prompt to reappear as you navigate, and
# n8n has its own owner-account login.
n8n.ghiath.id {
	reverse_proxy n8n:5678
}

# KeiRouter - the /v1 API must NOT sit behind basic_auth, because agents
# authenticate with an Authorization: Bearer <virtual-key> header that collides
# with Basic auth. The dashboard and everything else stays behind basic_auth for
# humans; KeiRouter's own virtual keys protect the API.
router.ghiath.id {
	@api path /v1 /v1/*
	handle @api {
		reverse_proxy keirouter:20180
	}
	handle {
		import protected
		reverse_proxy keirouter:20180
	}
}

# CouchDB for Obsidian LiveSync. No basic_auth: the LiveSync plugin
# authenticates with CouchDB's own user/password, and a second layer would
# break it.
couch.ghiath.id {
	reverse_proxy couchdb:5984
}

# ntfy - urgent push for reminder alarms. No basic_auth: ntfy runs deny-all with
# its own users and publish tokens, and a second layer would break both the
# phones' subscriptions and the reminder tick's token-authenticated publish.
ntfy.ghiath.id {
	reverse_proxy ntfy:80
}
