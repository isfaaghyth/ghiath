# Every vault, whatever it is named. This is a wildcard on purpose: the vault
# folder names are configurable in agents.conf, and a rename (vault ->
# vault-work) previously left the new folder tracked, which would have pushed
# private notes to the public repo the moment one was written.
vault*/
obsidian-vault/

.DS_Store
.idea/
.vscode/
.env.bak
livesync-bridge/config.json
ntfy/data/
# Private, machine-local hermes skills. Seeded into agents by hermes.sh but
# never pushed — personal/proprietary skills live here (see README).
skills-local/

# Python bytecode
__pycache__/
*.pyc
